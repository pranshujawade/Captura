{
  "$schema": "https://design-tokens.org/schema.json",
  "$metadata": {
    "brand": "Captura",
    "description": "W3C Design Tokens Community Group (DTCG) compliant token set for Captura. Derived from the Captura brand visual identity: deep black backgrounds, rich gold accents, warm cream text, and botanical-inspired decorative elements.",
    "version": "1.0.0",
    "spec": "https://tr.designtokens.org/format/"
  },

  "color": {
    "$description": "Core color palette. All values are raw primitives — do not use these directly in UI; reference semantic tokens instead.",

    "black": {
      "0": { "$value": "#000000", "$type": "color", "$description": "Pure black — deepest background" },
      "50": { "$value": "#0A0A08", "$type": "color", "$description": "Near-black with warm undertone — primary page background" },
      "100": { "$value": "#111108", "$type": "color", "$description": "Section background — subtle lift from base" },
      "150": { "$value": "#18170F", "$type": "color", "$description": "Card / surface background" },
      "200": { "$value": "#1F1E14", "$type": "color", "$description": "Elevated surface — modal, drawer" }
    },

    "gold": {
      "100": { "$value": "#F5E6A3", "$type": "color", "$description": "Light gold — highlight text, thin dividers" },
      "200": { "$value": "#E8CC6A", "$type": "color", "$description": "Pale gold — muted label text" },
      "300": { "$value": "#D4A843", "$type": "color", "$description": "Mid gold — secondary action tint" },
      "400": { "$value": "#C8952A", "$type": "color", "$description": "Core brand gold — primary CTA background, icon fills" },
      "500": { "$value": "#B8820F", "$type": "color", "$description": "Rich gold — hover state for primary CTA" },
      "600": { "$value": "#9A6B0A", "$type": "color", "$description": "Deep gold — pressed / active state" },
      "gradient-light": { "$value": "#F0D060", "$type": "color", "$description": "Gradient start — logo shine, hero text shimmer" },
      "gradient-dark": { "$value": "#8A5E05", "$type": "color", "$description": "Gradient end — logo depth, button gradient terminus" }
    },

    "cream": {
      "50": { "$value": "#FEFCF5", "$type": "color", "$description": "Off-white — primary body text on dark backgrounds" },
      "100": { "$value": "#F7F1DC", "$type": "color", "$description": "Warm cream — headings, pull quotes" },
      "200": { "$value": "#E8DCBB", "$type": "color", "$description": "Muted cream — secondary body copy, captions" },
      "300": { "$value": "#C9BC98", "$type": "color", "$description": "Dim cream — placeholder text, disabled labels" }
    },

    "overlay": {
      "black-40": { "$value": "#00000066", "$type": "color", "$description": "40% black overlay — image scrim" },
      "black-60": { "$value": "#00000099", "$type": "color", "$description": "60% black overlay — hero image scrim" },
      "black-80": { "$value": "#000000CC", "$type": "color", "$description": "80% black overlay — modal backdrop" },
      "gold-10": { "$value": "#C8952A1A", "$type": "color", "$description": "10% gold tint — card hover background" },
      "gold-20": { "$value": "#C8952A33", "$type": "color", "$description": "20% gold tint — active chip, tag background" }
    }
  },

  "gradient": {
    "$description": "Reusable gradient definitions following CSS linear-gradient / radial-gradient syntax.",

    "gold-shine": {
      "$value": "linear-gradient(135deg, #F0D060 0%, #C8952A 50%, #8A5E05 100%)",
      "$type": "color",
      "$description": "Primary brand gradient — logo, hero headings, premium CTAs"
    },
    "gold-horizontal": {
      "$value": "linear-gradient(90deg, #8A5E05 0%, #C8952A 40%, #F0D060 60%, #C8952A 80%, #8A5E05 100%)",
      "$type": "color",
      "$description": "Horizontal shimmer — decorative dividers, section separators"
    },
    "surface-depth": {
      "$value": "linear-gradient(180deg, #18170F 0%, #0A0A08 100%)",
      "$type": "color",
      "$description": "Dark surface depth — section backgrounds, cards"
    },
    "hero-scrim": {
      "$value": "linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.7) 100%)",
      "$type": "color",
      "$description": "Bottom-weighted scrim over hero photography"
    },
    "radial-glow": {
      "$value": "radial-gradient(ellipse 60% 40% at 50% 50%, rgba(200,149,42,0.18) 0%, rgba(0,0,0,0) 100%)",
      "$type": "color",
      "$description": "Subtle gold ambient glow — centered behind key icons / logo"
    }
  },

  "typography": {
    "$description": "Type system tokens. Two families used: a high-contrast serif for editorial headings and a geometric sans for UI / body copy.",

    "font-family": {
      "heading": {
        "$value": "'Cormorant Garamond', 'Garamond', 'Times New Roman', serif",
        "$type": "fontFamily",
        "$description": "High-contrast didone-style serif — section headings, pull quotes, brand statements"
      },
      "subheading": {
        "$value": "'Playfair Display', 'Georgia', serif",
        "$type": "fontFamily",
        "$description": "Transitional serif — subheadings, card titles"
      },
      "body": {
        "$value": "'Inter', 'Helvetica Neue', 'Arial', sans-serif",
        "$type": "fontFamily",
        "$description": "Neutral geometric sans — body copy, UI labels, navigation"
      },
      "display": {
        "$value": "'Cinzel', 'Trajan Pro', serif",
        "$type": "fontFamily",
        "$description": "All-caps spaced display — logo wordmark, section eyebrows (e.g. 'CAPTURA')"
      }
    },

    "font-size": {
      "$description": "Typographic scale — Major Third (1.25×) ratio from a 16px base.",
      "xs":   { "$value": "12px",  "$type": "dimension", "$description": "Legal text, footnotes" },
      "sm":   { "$value": "14px",  "$type": "dimension", "$description": "Captions, labels, nav items" },
      "base": { "$value": "16px",  "$type": "dimension", "$description": "Body copy default" },
      "md":   { "$value": "18px",  "$type": "dimension", "$description": "Lead paragraph, card body" },
      "lg":   { "$value": "20px",  "$type": "dimension", "$description": "Section subheadings" },
      "xl":   { "$value": "24px",  "$type": "dimension", "$description": "Card headings, sidebar titles" },
      "2xl":  { "$value": "30px",  "$type": "dimension", "$description": "Section headings (h3/h4)" },
      "3xl":  { "$value": "36px",  "$type": "dimension", "$description": "Page-level subheadings (h2)" },
      "4xl":  { "$value": "48px",  "$type": "dimension", "$description": "Hero subheading (h1 secondary)" },
      "5xl":  { "$value": "60px",  "$type": "dimension", "$description": "Hero headline primary" },
      "6xl":  { "$value": "72px",  "$type": "dimension", "$description": "Large editorial display text" }
    },

    "font-weight": {
      "light":    { "$value": "300", "$type": "fontWeight", "$description": "Long-form body, spacious editorial text" },
      "regular":  { "$value": "400", "$type": "fontWeight", "$description": "Default body weight" },
      "medium":   { "$value": "500", "$type": "fontWeight", "$description": "UI labels, nav items" },
      "semibold": { "$value": "600", "$type": "fontWeight", "$description": "Card titles, CTAs" },
      "bold":     { "$value": "700", "$type": "fontWeight", "$description": "Section headings" }
    },

    "line-height": {
      "tight":   { "$value": "1.1",  "$type": "number", "$description": "Large display headlines" },
      "snug":    { "$value": "1.25", "$type": "number", "$description": "Subheadings, card titles" },
      "normal":  { "$value": "1.5",  "$type": "number", "$description": "Standard body copy" },
      "relaxed": { "$value": "1.65", "$type": "number", "$description": "Long-form editorial paragraphs" },
      "loose":   { "$value": "2.0",  "$type": "number", "$description": "Spaced UI labels, captions" }
    },

    "letter-spacing": {
      "tight":   { "$value": "-0.02em", "$type": "dimension", "$description": "Large serif headings" },
      "normal":  { "$value": "0em",     "$type": "dimension", "$description": "Body text default" },
      "wide":    { "$value": "0.05em",  "$type": "dimension", "$description": "UI labels, button text" },
      "wider":   { "$value": "0.1em",   "$type": "dimension", "$description": "Nav items, eyebrow labels" },
      "widest":  { "$value": "0.2em",   "$type": "dimension", "$description": "All-caps display wordmarks (CAPTURA)" }
    }
  },

  "spacing": {
    "$description": "Spacing scale using an 8px base grid. All layout spacing must use values from this scale.",
    "0":   { "$value": "0px",   "$type": "dimension" },
    "1":   { "$value": "4px",   "$type": "dimension", "$description": "Micro — icon gap, tight list items" },
    "2":   { "$value": "8px",   "$type": "dimension", "$description": "XS — inline padding, small gaps" },
    "3":   { "$value": "12px",  "$type": "dimension", "$description": "SM — compact input padding" },
    "4":   { "$value": "16px",  "$type": "dimension", "$description": "Base — standard component padding" },
    "5":   { "$value": "20px",  "$type": "dimension", "$description": "MD — card internal padding" },
    "6":   { "$value": "24px",  "$type": "dimension", "$description": "LG — section internal gap" },
    "8":   { "$value": "32px",  "$type": "dimension", "$description": "XL — between components" },
    "10":  { "$value": "40px",  "$type": "dimension", "$description": "2XL — section top/bottom padding (mobile)" },
    "12":  { "$value": "48px",  "$type": "dimension", "$description": "3XL — section vertical rhythm" },
    "16":  { "$value": "64px",  "$type": "dimension", "$description": "4XL — hero vertical padding" },
    "20":  { "$value": "80px",  "$type": "dimension", "$description": "5XL — large section vertical padding" },
    "24":  { "$value": "96px",  "$type": "dimension", "$description": "6XL — page-top hero offset" },
    "32":  { "$value": "128px", "$type": "dimension", "$description": "7XL — full-bleed section breathing room" }
  },

  "border-radius": {
    "none":  { "$value": "0px",   "$type": "dimension", "$description": "Square edges — decorative dividers, hero overlays" },
    "xs":    { "$value": "2px",   "$type": "dimension", "$description": "Subtle rounding — tags, chips" },
    "sm":    { "$value": "4px",   "$type": "dimension", "$description": "Inputs, secondary buttons" },
    "md":    { "$value": "6px",   "$type": "dimension", "$description": "Cards, primary buttons" },
    "lg":    { "$value": "8px",   "$type": "dimension", "$description": "Modal, panels" },
    "xl":    { "$value": "12px",  "$type": "dimension", "$description": "Feature cards with imagery" },
    "2xl":   { "$value": "16px",  "$type": "dimension", "$description": "Large rounded containers" },
    "pill":  { "$value": "9999px","$type": "dimension", "$description": "Badge, stat pill, rounded CTA" },
    "full":  { "$value": "50%",   "$type": "dimension", "$description": "Circular avatar, icon container" }
  },

  "border": {
    "width": {
      "thin":   { "$value": "1px", "$type": "dimension" },
      "medium": { "$value": "2px", "$type": "dimension" },
      "thick":  { "$value": "3px", "$type": "dimension" }
    },
    "style": {
      "solid":  { "$value": "solid",  "$type": "string" },
      "dashed": { "$value": "dashed", "$type": "string" }
    },
    "color": {
      "default":  { "$value": "{color.gold.400}",    "$type": "color", "$description": "Standard gold border — card outlines, dividers" },
      "subtle":   { "$value": "{color.gold.gradient-dark}", "$type": "color", "$description": "Low-contrast border — input idle state" },
      "strong":   { "$value": "{color.gold.gradient-light}", "$type": "color", "$description": "High-contrast border — focus ring, hover" },
      "surface":  { "$value": "{color.black.200}",   "$type": "color", "$description": "Dark border between surfaces" }
    }
  },

  "shadow": {
    "$description": "Elevation shadows. Use gold-tinted glow for interactive elements, neutral for structural surfaces.",
    "xs":     { "$value": "0 1px 2px rgba(0,0,0,0.6)",                                                             "$type": "shadow" },
    "sm":     { "$value": "0 2px 8px rgba(0,0,0,0.7)",                                                             "$type": "shadow" },
    "md":     { "$value": "0 4px 16px rgba(0,0,0,0.8)",                                                            "$type": "shadow" },
    "lg":     { "$value": "0 8px 32px rgba(0,0,0,0.85)",                                                           "$type": "shadow" },
    "xl":     { "$value": "0 16px 48px rgba(0,0,0,0.9)",                                                           "$type": "shadow" },
    "gold-glow-sm":  { "$value": "0 0 12px rgba(200,149,42,0.4)",                                                  "$type": "shadow", "$description": "Soft gold glow — icon hover, CTA focus" },
    "gold-glow-md":  { "$value": "0 0 24px rgba(200,149,42,0.5), 0 4px 16px rgba(0,0,0,0.8)",                     "$type": "shadow", "$description": "Medium gold glow — card hover, logo" },
    "gold-glow-lg":  { "$value": "0 0 48px rgba(200,149,42,0.6), 0 8px 32px rgba(0,0,0,0.9)",                     "$type": "shadow", "$description": "Large gold aura — hero elements, primary CTA hover" },
    "inset-dark":    { "$value": "inset 0 1px 3px rgba(0,0,0,0.8)",                                               "$type": "shadow", "$description": "Input field inset depth" }
  },

  "motion": {
    "$description": "Animation and transition tokens following WCAG 2.3 — all durations respect prefers-reduced-motion.",

    "duration": {
      "instant":    { "$value": "0ms",   "$type": "duration" },
      "fast":       { "$value": "120ms", "$type": "duration", "$description": "Hover state micro-interactions" },
      "normal":     { "$value": "200ms", "$type": "duration", "$description": "Standard transitions" },
      "moderate":   { "$value": "300ms", "$type": "duration", "$description": "Panel open/close, dropdowns" },
      "slow":       { "$value": "500ms", "$type": "duration", "$description": "Page-level enter animations" },
      "deliberate": { "$value": "700ms", "$type": "duration", "$description": "Hero text reveals, shimmer sweeps" }
    },

    "easing": {
      "linear":       { "$value": "linear",                        "$type": "cubicBezier" },
      "ease-in":      { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" },
      "ease-out":     { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" },
      "ease-in-out":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Default smooth — most UI transitions" },
      "spring":       { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "Overshoot spring — icon pop, badge appear" }
    }
  },

  "opacity": {
    "disabled": { "$value": "0.38", "$type": "number", "$description": "WCAG-derived disabled state" },
    "muted":    { "$value": "0.6",  "$type": "number", "$description": "Secondary text, inactive icons" },
    "subtle":   { "$value": "0.8",  "$type": "number", "$description": "Slightly de-emphasised elements" },
    "full":     { "$value": "1",    "$type": "number" }
  },

  "z-index": {
    "below":    { "$value": "-1",  "$type": "number", "$description": "Background layers, pseudo overlays" },
    "base":     { "$value": "0",   "$type": "number" },
    "raised":   { "$value": "10",  "$type": "number", "$description": "Cards, section decorations" },
    "dropdown": { "$value": "100", "$type": "number", "$description": "Navigation dropdowns, tooltips" },
    "sticky":   { "$value": "200", "$type": "number", "$description": "Sticky nav bar" },
    "overlay":  { "$value": "300", "$type": "number", "$description": "Image overlays, drawers" },
    "modal":    { "$value": "400", "$type": "number", "$description": "Modal dialogs" },
    "toast":    { "$value": "500", "$type": "number", "$description": "Notification toasts" }
  },

  "breakpoint": {
    "$description": "Responsive breakpoints — mobile-first.",
    "sm":  { "$value": "640px",  "$type": "dimension", "$description": "Large mobile landscape" },
    "md":  { "$value": "768px",  "$type": "dimension", "$description": "Tablet portrait" },
    "lg":  { "$value": "1024px", "$type": "dimension", "$description": "Tablet landscape / small desktop" },
    "xl":  { "$value": "1280px", "$type": "dimension", "$description": "Standard desktop" },
    "2xl": { "$value": "1536px", "$type": "dimension", "$description": "Wide desktop" }
  },

  "semantic": {
    "$description": "Semantic decision tokens. These are what UI components should reference — never raw primitives.",

    "background": {
      "page":      { "$value": "{color.black.50}",  "$type": "color", "$description": "Root page background" },
      "section-alt": { "$value": "{color.black.100}", "$type": "color", "$description": "Alternating section background" },
      "surface":   { "$value": "{color.black.150}", "$type": "color", "$description": "Card / panel background" },
      "elevated":  { "$value": "{color.black.200}", "$type": "color", "$description": "Modal / dropdown background" },
      "overlay":   { "$value": "{color.overlay.black-80}", "$type": "color", "$description": "Full-screen modal scrim" }
    },

    "text": {
      "primary":   { "$value": "{color.cream.100}",  "$type": "color", "$description": "Main headings, body copy" },
      "secondary": { "$value": "{color.cream.200}",  "$type": "color", "$description": "Supporting copy, descriptions" },
      "muted":     { "$value": "{color.cream.300}",  "$type": "color", "$description": "Placeholders, disabled labels" },
      "accent":    { "$value": "{color.gold.400}",   "$type": "color", "$description": "Gold accent text — links, highlights" },
      "on-gold":   { "$value": "{color.black.50}",   "$type": "color", "$description": "Text rendered on a gold surface (CTA buttons)" },
      "inverse":   { "$value": "{color.black.50}",   "$type": "color", "$description": "Text on light surfaces (rare)" }
    },

    "action": {
      "primary-bg":         { "$value": "{color.gold.400}",       "$type": "color", "$description": "Primary CTA button background" },
      "primary-bg-hover":   { "$value": "{color.gold.500}",       "$type": "color", "$description": "Primary CTA hover" },
      "primary-bg-active":  { "$value": "{color.gold.600}",       "$type": "color", "$description": "Primary CTA pressed" },
      "primary-text":       { "$value": "{color.black.50}",       "$type": "color", "$description": "Text on primary CTA" },
      "secondary-bg":       { "$value": "transparent",            "$type": "color", "$description": "Ghost / outline button background" },
      "secondary-border":   { "$value": "{color.gold.400}",       "$type": "color", "$description": "Ghost button border" },
      "secondary-text":     { "$value": "{color.gold.400}",       "$type": "color", "$description": "Ghost button text" },
      "secondary-hover-bg": { "$value": "{color.overlay.gold-10}","$type": "color", "$description": "Ghost button hover fill" }
    },

    "icon": {
      "default":  { "$value": "{color.gold.300}",  "$type": "color" },
      "active":   { "$value": "{color.gold.400}",  "$type": "color" },
      "muted":    { "$value": "{color.cream.300}", "$type": "color" }
    },

    "divider": {
      "default": { "$value": "{color.gold.gradient-dark}", "$type": "color", "$description": "Horizontal rule, section separator" },
      "strong":  { "$value": "{color.gold.400}",           "$type": "color", "$description": "Feature divider with glow" }
    },

    "focus-ring": {
      "color":  { "$value": "{color.gold.300}", "$type": "color" },
      "width":  { "$value": "2px",              "$type": "dimension" },
      "offset": { "$value": "3px",              "$type": "dimension" }
    },

    "nav": {
      "bg":           { "$value": "{color.black.50}",       "$type": "color", "$description": "Navbar background — semi-transparent on scroll" },
      "bg-scrolled":  { "$value": "{color.black.150}",      "$type": "color", "$description": "Navbar background after scroll" },
      "item-text":    { "$value": "{color.cream.200}",      "$type": "color" },
      "item-hover":   { "$value": "{color.gold.300}",       "$type": "color" },
      "item-active":  { "$value": "{color.gold.400}",       "$type": "color" },
      "dropdown-bg":  { "$value": "{color.black.200}",      "$type": "color" },
      "dropdown-border": { "$value": "{color.gold.gradient-dark}", "$type": "color" }
    }
  }
}
